modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
WALLET_OWNER_TOKEN = "bf9a6cbff0c92978a764e596ba894b59face98b4847bc5f85aa7907f3c402b64"
EXPO_PUBLIC_WALLET_OWNER_TOKEN = "bf9a6cbff0c92978a764e596ba894b59face98b4847bc5f85aa7907f3c402b64"
