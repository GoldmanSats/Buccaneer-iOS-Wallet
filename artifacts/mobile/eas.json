{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_BREEZ_API_KEY": "${BREEZ_API_KEY}"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_BREEZ_API_KEY": "${BREEZ_API_KEY}"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "autoCredentials": true
      },
      "env": {
        "EXPO_PUBLIC_BREEZ_API_KEY": "${BREEZ_API_KEY}"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {}
    }
  }
}
