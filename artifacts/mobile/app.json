{
  "expo": {
    "name": "Buccaneer Wallet",
    "slug": "buccaneer-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "buccaneer-wallet",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1426"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.buccaneer.wallet",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Buccaneer Wallet uses Face ID to secure your wallet"
      }
    },
    "android": {
      "package": "com.buccaneer.wallet"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Buccaneer Wallet uses Face ID to protect your wallet"
        }
      ],
      "expo-local-authentication",
      "@breeztech/breez-sdk-spark-react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
